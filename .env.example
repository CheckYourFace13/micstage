DATABASE_URL="file:./dev.db"
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your_google_maps_api_key"
AUTH_SECRET="generate_a_long_random_string"

# Next.js server actions: set a stable secret in production so action payloads decrypt correctly across deploys and server
# instances. Generate once per environment (e.g. openssl rand -base64 32) and keep it in your host’s build/runtime env.
# Without it, users can see stale-action errors until they hard refresh after a deploy.
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=""

# Internal launch dashboard: GET /internal/launch-metrics?key=<this> sets a short-lived cookie; unset = route returns 404.
# MICSTAGE_LAUNCH_METRICS_SECRET="long_random_string"

# Internal operations admin: /internal/admin (and login). Unset = entire tree returns 404.
# Optional comma-separated allowlist — if set, operators must enter one of these emails at sign-in (or ?email= on key URL).
# MICSTAGE_ADMIN_SECRET="long_random_string"
# MICSTAGE_ADMIN_EMAILS="ops@yourdomain.com,other@yourdomain.com"
# Optional: logs admin secret presence (never the value) when hitting GET /api/debug-admin-env only.
# MICSTAGE_ADMIN_DEBUG_LOG=1
# Canonical URL for emails, sitemap, Open Graph — use your real production domain.
APP_URL="https://micstage.com"
# Same as APP_URL in production when the browser needs the public origin.
NEXT_PUBLIC_APP_URL="https://micstage.com"

# Server-only inbox for /contact form (Resend). Not shown on the site. Legacy: NEXT_PUBLIC_CONTACT_EMAIL still works as a fallback for the same purpose.
# MICSTAGE_CONTACT_INBOX="hello@micstage.com"

# Password reset email (optional in local dev; required for production)
RESEND_API_KEY=""
EMAIL_FROM="MicStage <no-reply@micstage.com>"

# Booking reminders: external scheduler (e.g. Hostinger cron / cron-job.org) calls GET/POST /api/cron/booking-reminders
# with Authorization: Bearer <secret>. See docs/BOOKING_REMINDERS.md
# CRON_SECRET="long_random_string"
# Or: MICSTAGE_CRON_SECRET="long_random_string"
# Optional: MICSTAGE_DISABLE_BOOKING_REMINDERS=1

# Weekly nearby open mic digest (artists who opt in on /artist profile): GET/POST /api/cron/weekly-open-mic-digest
# with the same CRON_SECRET / MICSTAGE_CRON_SECRET as booking reminders. Schedule ~once per week externally.
# Optional: MICSTAGE_DISABLE_WEEKLY_DIGEST=1

# Daily owner summary (8:00 America/Chicago): GET/POST /api/cron/daily-owner-summary with CRON_SECRET / MICSTAGE_CRON_SECRET.
# Preview & manual send: /internal/admin/owner-summary
# MICSTAGE_OWNER_SUMMARY_EMAIL="chris@iscreamstudio.com"   (or MICSTAGE_OWNER_SUMMARY_TO)
# MICSTAGE_DISABLE_OWNER_SUMMARY=1
# MICSTAGE_OWNER_SUMMARY_SKIP_TIME_GUARD=1   (cron only: send outside 8am Chicago window)
# Force immediate send from cron: ?force=1

# Production Postgres example (switch DATABASE_URL when deploying):
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/micstage?schema=public"

# Analytics (optional)
# Vercel: enable “Web Analytics” on the project; @vercel/analytics sends pageviews + custom events in production.
# Set to 1 to disable all analytics script + client event bridge (pageviews and product events).
# NEXT_PUBLIC_DISABLE_ANALYTICS=1

# Sentry error monitoring (optional). If unset, the SDK stays disabled (no DSN in repo).
# Use the same ingest URL for both in production, or server-only SENTRY_DSN if you prefer.
# SENTRY_DSN="https://xxxx@xxxx.ingest.us.sentry.io/xxxx"
# NEXT_PUBLIC_SENTRY_DSN="https://xxxx@xxxx.ingest.us.sentry.io/xxxx"
# Optional: label issues (e.g. production / preview). Defaults to NODE_ENV on the client.
# NEXT_PUBLIC_SENTRY_ENV="production"

# Source maps in CI (optional): set webpack.disableSentryConfig to false in next.config.ts, then set:
# SENTRY_AUTH_TOKEN=""
# SENTRY_ORG=""
# SENTRY_PROJECT=""

# --- Growth pipeline (cron: GET/POST /api/cron/growth-pipeline with CRON_SECRET or MICSTAGE_CRON_SECRET) ---
# GROWTH_LEAD_DISCOVERY_CRON_ENABLED=true
# GROWTH_DISCOVERY_MARKET_SLUGS="chicagoland-il"
# Per-adapter per-market cap per cron run (raise for volume; dedupe reduces net new rows).
# GROWTH_DISCOVERY_MAX_CANDIDATES_PER_ADAPTER=400
# High-volume autonomous discovery (web search + optional crawl + Eventbrite). Requires migration: GrowthDiscoveryCursor.
# GROWTH_DISCOVERY_AUTONOMOUS_ENABLED=true   (also accepts 1, yes, on — case-insensitive)
# SerpAPI (primary) + Brave Search API (fallback when Serp is gated or HTTP fails). Get Brave key: https://api.search.brave.com
# GROWTH_BRAVE_SEARCH_API_KEY=""   (or BRAVE_SEARCH_API_KEY)
# GROWTH_SERPAPI_KEY=""   (or SERPAPI_KEY / SERPAPI_API_KEY if already set in hosting)
# SerpAPI is premium/capped; Brave covers nationwide when Serp is unavailable.
# GROWTH_SERPAPI_ENABLED=true
# GROWTH_SERPAPI_DAILY_MAX=8
# GROWTH_SERPAPI_MONTHLY_SOFT_MAX=240
# GROWTH_SERPAPI_COOLDOWN_HOURS_ON_429=24
# GROWTH_SERPAPI_RUNS_PER_DAY=1
# Optional ops model:
# GROWTH_SERPAPI_COST_PER_CALL_USD=0.0
# GROWTH_DISCOVERY_AUTONOMOUS_SEARCH_CALLS_PER_RUN=8
# GROWTH_DISCOVERY_AUTONOMOUS_PAGE_FETCHES_PER_RUN=40
# GROWTH_DISCOVERY_HTTP_DELAY_MS=150
# Comma-separated roots to crawl when autonomous enabled (venues, directories you operate).
# GROWTH_DISCOVERY_CRAWL_SEED_URLS="https://example-venue.com,https://another.com"
# GROWTH_DISCOVERY_CRAWL_MAX_SEEDS_PER_RUN=15
# Eventbrite expansion tuning:
# GROWTH_EVENTBRITE_RADIUS_KM=70km
# Eventbrite private token (event search). Also accepts legacy EVENTBRITE_PRIVATE_TOKEN.
# GROWTH_EVENTBRITE_TOKEN=""
# Large starter batch: JSON array or { "leads": [...] }. Max ~1.5M chars.
# GROWTH_DISCOVERY_STUB_LEADS_JSON='[{"name":"Example Venue","leadType":"VENUE","discoveryMarketSlug":"chicagoland-il","sourceKind":"SCHEDULED_JOB"}]'
# Outreach caps (UTC): MARKETING_CAP_DAILY_OUTREACH (default 30), MARKETING_CAP_PER_DOMAIN_DAILY_OUTREACH or legacy MARKETING_CAP_PER_DOMAIN_DAILY (default 5), MARKETING_CAP_PER_DOMAIN_DAILY_MARKETING (marketing category), MARKETING_CONTACT_COOLDOWN_HOURS (default 168 = 7d). Automated growth outreach: HIGH confidence only unless GROWTH_OUTREACH_ALLOW_MEDIUM_CONFIDENCE=true.
# GROWTH_AUTO_DRAFT_CRON_ENABLED=false
# Smooth outreach bursts: successful sends per growth-pipeline run (1–5, default 4). Daily/domain caps unchanged.
# GROWTH_OUTREACH_SENDS_PER_CRON_RUN=4
