DATABASE_URL="file:./dev.db"
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your_google_maps_api_key"
AUTH_SECRET="generate_a_long_random_string"
# Canonical URL for emails, sitemap, Open Graph — use your real production domain.
APP_URL="https://micstage.com"
# Same as APP_URL in production when the browser needs the public origin.
NEXT_PUBLIC_APP_URL="https://micstage.com"

# Password reset email (optional in local dev; required for production)
RESEND_API_KEY=""
EMAIL_FROM="MicStage <no-reply@micstage.com>"

# Production Postgres example (switch DATABASE_URL when deploying):
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/micstage?schema=public"
