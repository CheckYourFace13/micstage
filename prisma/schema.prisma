// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum VenueRole {
  ADMIN
  MANAGER
}

enum Weekday {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

enum SlotStatus {
  AVAILABLE
  RESERVED
  CANCELLED
}

// What acts / setups the venue allows (one primary choice for search).
enum VenuePerformanceFormat {
  OPEN_VARIETY
  ACOUSTIC_ONLY
  GUITAR_VOCAL_ONLY
  FULL_BANDS_ALLOWED
  /// Legacy; no longer offered in UI — migrated rows use COMEDY or SPOKEN_WORD.
  COMEDY_SPOKEN_WORD
  COMEDY
  SPOKEN_WORD
}

enum SubscriptionTier {
  FREE
  PRO
}

enum BookingRestrictionMode {
  NONE
  ATTENDEE_DAY_OF
  HOURS_BEFORE
  ON_PREMISE
  /// Public artists cannot book; venue assigns via house booking only.
  HOUSE_ONLY
}

enum PasswordResetAccountType {
  VENUE
  MUSICIAN
}

/// Row in venue performer history: linked MicStage artist vs manual lineup-only name.
enum VenuePerformerHistoryKind {
  MUSICIAN
  MANUAL
}

model VenueOwner {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  email        String @unique
  passwordHash String

  /// Set on registration when the operator accepts Terms, Privacy, and platform content/promotional use.
  registrationContentConsentAt      DateTime?
  registrationContentConsentVersion String?

  venues Venue[]
}

model Venue {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner   VenueOwner @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String

  name String
  slug String @unique

  // Google Places reference
  googlePlaceId    String @unique
  formattedAddress String
  city             String?
  region           String?
  country          String?
  lat              Float?
  lng              Float?
  timeZone         String  @default("America/Chicago")

  // Profile (searchable later)
  about String?
  // Direct media fields for public profile
  logoUrl         String?
  imagePrimaryUrl String?
  imageSecondaryUrl String?

  // Website + socials
  websiteUrl       String?
  facebookUrl      String?
  instagramUrl     String?
  twitterUrl       String?
  tiktokUrl        String?
  youtubeUrl       String?
  soundcloudUrl    String?

  // Open mic series window (optional). If set, slots/bookings only allowed inside this range.
  seriesStartDate DateTime?
  seriesEndDate   DateTime?

  // How many calendar days ahead from today performers may book (e.g. 60).
  bookingOpensDaysAhead Int @default(60)

  subscriptionTier SubscriptionTier @default(FREE)

  // How bookings are released within the booking window.
  bookingRestrictionMode BookingRestrictionMode @default(NONE)
  // For HOURS_BEFORE and ON_PREMISE: only allow booking within this many hours before slot start.
  restrictionHoursBefore Int @default(6)
  // For ON_PREMISE: max allowed distance from venue (meters) for booking.
  onPremiseMaxDistanceMeters Int @default(1000)

  /// Legacy default when creating templates; each `EventTemplate` stores its own format for public display.
  performanceFormat VenuePerformanceFormat @default(OPEN_VARIETY)

  // What the venue provides for musicians (filterable later)
  providesPA             Boolean @default(false)
  providesSpeakersMics   Boolean @default(false)
  providesMonitors       Boolean @default(false)
  providesDrumKit        Boolean @default(false)
  providesBassAmp        Boolean @default(false)
  providesGuitarAmp      Boolean @default(false)
  providesKeyboard       Boolean @default(false)
  providesDiBox          Boolean @default(false)
  providesLightingBasic  Boolean @default(false)
  providesBacklineShared Boolean @default(false)

  managerAccess VenueManagerAccess[]

  eventTemplates EventTemplate[]

  pastPerformers        MusicianPastVenue[]
  interestedMusicians   MusicianVenueInterest[]
  performerHistory      VenuePerformerHistory[]

  marketingEvents         MarketingEvent[]
  marketingJobs           MarketingJob[]
  marketingContacts       MarketingContact[]
  marketingEmailSends     MarketingEmailSend[]
  marketingOutreachDrafts MarketingOutreachDraft[]
}

model VenueManager {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  email        String @unique
  passwordHash String

  access VenueManagerAccess[]
}

model VenueManagerAccess {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  venue   Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)
  venueId String

  manager   VenueManager @relation(fields: [managerId], references: [id], onDelete: Cascade)
  managerId String

  role VenueRole @default(MANAGER)

  @@unique([venueId, managerId])
  @@index([managerId])
}

model MusicianUser {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  email        String @unique
  passwordHash String

  /// Set on registration when the artist accepts Terms, Privacy, and platform content/promotional use.
  registrationContentConsentAt      DateTime?
  registrationContentConsentVersion String?

  stageName String

  firstName String?
  lastName  String?
  bio       String?

  websiteUrl   String?
  imageUrl     String?
  /// Optional second public photo (URL or uploaded asset URL).
  imageSecondaryUrl String?
  facebookUrl  String?
  instagramUrl String?
  twitterUrl   String?
  tiktokUrl    String?
  youtubeUrl   String?
  soundcloudUrl String?

  // Stored as JSON string arrays, e.g. ["VOCALS","GUITAR"]
  specializations Json?
  instruments     Json?

  yearsPlaying Int?
  openToHire   Boolean @default(false)

  hireRateDescription String?
  setLengthMinutes    Int?

  collaborationsText String?

  // Home base for discovery / future radius search & email targeting (city pick from Google or manual city/region).
  homeGooglePlaceId     String?
  homeFormattedAddress  String?
  homeLat               Float?
  homeLng               Float?
  homeCity              String?
  homeRegion            String?
  // How far from home base they’ll travel to perform (miles).
  travelRadiusMiles     Int?

  // Optional second area + radius (e.g. frequent second market).
  secondaryGooglePlaceId     String?
  secondaryFormattedAddress  String?
  secondaryLat               Float?
  secondaryLng               Float?
  secondaryCity              String?
  secondaryRegion            String?
  secondaryRadiusMiles       Int?

  bookings          Booking[]
  pastVenues        MusicianPastVenue[]
  interestedVenues  MusicianVenueInterest[]
  venuePerformerHistory            VenuePerformerHistory[] @relation("VenuePerformerHistoryMusician")
  venuePerformerHistoryManualLinks VenuePerformerHistory[] @relation("VenuePerformerHistoryManualLink")
}

/// Deduplicated performers who have appeared (or been typed) on a venue lineup — for autocomplete, dashboard review, and optional public “past performers”.
model VenuePerformerHistory {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  venueId String
  venue   Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)

  kind VenuePerformerHistoryKind
  /// MUSICIAN: musicianId; MANUAL: normalized lowercase name for dedupe (see app logic).
  key  String

  musicianId String?
  musician   MusicianUser? @relation("VenuePerformerHistoryMusician", fields: [musicianId], references: [id], onDelete: SetNull)

  /// Shown on lineups and lists (stage name or manual entry).
  displayName String

  lastUsedAt DateTime @default(now())
  useCount   Int      @default(1)

  /// Manual rows: venue can hide from public venue page. Linked musicians use stage name only (always public-safe when shown).
  showOnPublicProfile Boolean @default(true)

  /// Optional manual row linked to a real account (venue-confirmed later; no auto-merge).
  linkedMusicianId String?
  linkedMusician   MusicianUser? @relation("VenuePerformerHistoryManualLink", fields: [linkedMusicianId], references: [id], onDelete: SetNull)

  @@unique([venueId, kind, key])
  @@index([venueId, lastUsedAt(sort: Desc)])
  @@index([venueId, kind])
}

// Venues this musician says they have performed at (marketing + trust signals).
model MusicianPastVenue {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  musician   MusicianUser @relation(fields: [musicianId], references: [id], onDelete: Cascade)
  musicianId String
  venue      Venue        @relation(fields: [venueId], references: [id], onDelete: Cascade)
  venueId    String

  @@unique([musicianId, venueId])
  @@index([venueId])
}

// Venues the musician wants to track / explore (open mics near them).
model MusicianVenueInterest {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  musician   MusicianUser @relation(fields: [musicianId], references: [id], onDelete: Cascade)
  musicianId String
  venue      Venue        @relation(fields: [venueId], references: [id], onDelete: Cascade)
  venueId    String

  @@unique([musicianId, venueId])
  @@index([venueId])
}

model EventTemplate {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  venue   Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)
  venueId String

  title       String
  description String?

  weekday      Weekday
  startTimeMin Int // minutes from midnight, local to tz
  endTimeMin   Int // minutes from midnight, local to tz
  timeZone     String @default("America/Chicago")

  slotMinutes  Int
  breakMinutes Int @default(0)

  isPublic Boolean @default(true)

  /// Acts / setups allowed for this schedule block (public + search).
  performanceFormat VenuePerformanceFormat @default(OPEN_VARIETY)

  // Booking release rules for this specific time block.
  bookingRestrictionMode BookingRestrictionMode @default(NONE)
  restrictionHoursBefore Int @default(6)
  onPremiseMaxDistanceMeters Int @default(1000)

  instances EventInstance[]

  @@index([venueId, weekday])
}

model EventInstance {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  template   EventTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId String

  // stored as midnight UTC for the local date
  date DateTime

  startTimeMinOverride Int?
  endTimeMinOverride   Int?
  isCancelled          Boolean @default(false)

  slots Slot[]

  @@unique([templateId, date])
  @@index([date])
}

model Slot {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  instance   EventInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  instanceId String

  startMin Int
  endMin   Int

  status SlotStatus @default(AVAILABLE)

  /// Shown on public lineup when there is no active booking (venue-filled placeholder name).
  manualLineupLabel String?

  /// When set, public booking + restrictions use these instead of the template defaults.
  bookingRestrictionModeOverride BookingRestrictionMode?
  restrictionHoursBeforeOverride Int?
  onPremiseMaxDistanceMetersOverride Int?

  booking Booking?

  @@unique([instanceId, startMin])
  @@index([instanceId, status])
}

model Booking {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  slot   Slot   @relation(fields: [slotId], references: [id], onDelete: Cascade)
  slotId String @unique

  musician   MusicianUser? @relation(fields: [musicianId], references: [id], onDelete: SetNull)
  musicianId String?

  performerName  String
  performerEmail String?
  notes          String?

  cancelledAt DateTime?

  /// Set when the ~24h-before-show email was successfully claimed/sent (idempotency).
  reminderEmail24hSentAt DateTime?
  /// Set when the ~2h-before-show email was successfully claimed/sent (idempotency).
  reminderEmail2hSentAt DateTime?

  @@index([musicianId])
  @@index([cancelledAt, reminderEmail24hSentAt])
  @@index([cancelledAt, reminderEmail2hSentAt])
}

model PasswordResetToken {
  id          String                   @id @default(cuid())
  createdAt   DateTime                 @default(now())
  accountType PasswordResetAccountType
  email       String
  tokenHash   String                   @unique
  expiresAt   DateTime
  usedAt      DateTime?

  @@index([email, accountType])
  @@index([expiresAt])
}

model AuthRateLimitCounter {
  id      String   @id @default(cuid())
  key     String
  bucket  String
  count   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([key, bucket])
  @@index([updatedAt])
}

// --- MicStage marketing automation (controlled live beta; deliverability + compliance) ---

enum MarketingEventType {
  INTERNAL_AUDIT
  JOB_ENQUEUED
  JOB_COMPLETED
  JOB_FAILED
  CONTACT_UPSERTED
  SUPPRESSION_RECORDED
  DRAFT_MATERIALIZED
  EMAIL_SENT
  EMAIL_BLOCKED
  EMAIL_FAILED
}

enum MarketingContactStatus {
  ACTIVE
  UNSUBSCRIBED
  BOUNCED
  COMPLAINED
  REPLIED
  DO_NOT_CONTACT
}

enum MarketingEmailCategory {
  TRANSACTIONAL
  OUTREACH
  MARKETING
}

enum MarketingEmailSendStatus {
  QUEUED
  SENT
  BLOCKED
  FAILED
}

enum MarketingOutreachDraftStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  SENT
  REJECTED
}

enum MarketingJobStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum MarketingJobKind {
  VENUE_OUTREACH_DRAFT
  EMAIL_PAYLOAD_RENDER
  SOCIAL_PAYLOAD_RENDER
  INDEXABILITY_SNAPSHOT
}

enum MarketingSuppressionReason {
  UNSUBSCRIBE
  HARD_BOUNCE
  COMPLAINT
  ADMIN_SUPPRESS
}

/// Append-only internal log for marketing operations (audits, dry-runs, future sends).
model MarketingEvent {
  id        String             @id @default(cuid())
  createdAt DateTime           @default(now())
  type      MarketingEventType
  /// Discovery rollup slug from `primaryDiscoverySlugForVenue` / locations directory (optional context).
  discoveryMarketSlug String?
  actorEmail          String?

  venueId String?
  venue   Venue? @relation(fields: [venueId], references: [id], onDelete: SetNull)

  contactId String?
  contact   MarketingContact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  jobId String?
  job   MarketingJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  /// Non-PII JSON metadata only (no email bodies in phase 1).
  payload Json?

  @@index([createdAt])
  @@index([type])
  @@index([discoveryMarketSlug])
  @@index([venueId])
  @@index([jobId])
}

/// Durable job queue for future workers; phase 1 records jobs only (no outbound dispatch).
model MarketingJob {
  id        String             @id @default(cuid())
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  status    MarketingJobStatus @default(PENDING)
  kind      MarketingJobKind

  /// Process at or after this time (null = as soon as possible).
  runAfter DateTime?
  attempts Int                 @default(0)
  maxAttempts Int              @default(5)

  /// Dedupe key for idempotent enqueue (optional).
  idempotencyKey String? @unique

  discoveryMarketSlug String?

  venueId String?
  venue   Venue? @relation(fields: [venueId], references: [id], onDelete: SetNull)

  contactId String?
  contact   MarketingContact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  /// Parameters / refs (no secrets).
  payload   Json?
  lastError String?

  events MarketingEvent[]

  @@index([status, runAfter])
  @@index([kind, status])
  @@index([venueId])
}

/// Outreach identity; keep separate from product auth accounts.
model MarketingContact {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  emailNormalized String @unique
  displayName     String?

  venueId String?
  venue   Venue? @relation(fields: [venueId], references: [id], onDelete: SetNull)

  /// Discovery market context for rollups (optional).
  discoveryMarketSlug String?

  source String?
  notes  String?
  meta   Json?

  /// Primary lifecycle state for outreach (kept in sync with unsubscribe/suppression flows).
  status MarketingContactStatus @default(ACTIVE)

  /// SHA-256 hex of raw unsubscribe token (raw token only appears in email links).
  unsubscribeTokenHash String? @unique

  repliedAt DateTime?

  /// User-initiated marketing opt-out (separate from technical suppression).
  marketingUnsubscribedAt DateTime?

  /// Hard block for any future outreach (bounces, complaints, admin).
  suppressedAt          DateTime?
  suppressionReason     MarketingSuppressionReason?

  jobs            MarketingJob[]
  events          MarketingEvent[]
  emailSends      MarketingEmailSend[]
  outreachDrafts  MarketingOutreachDraft[]
  growthLeadOutreachDrafts GrowthLeadOutreachDraft[]

  @@index([discoveryMarketSlug])
  @@index([suppressedAt])
  @@index([marketingUnsubscribedAt])
  @@index([status])
}

/// Venue cold outreach: approval required before live send (default PENDING_REVIEW).
model MarketingOutreachDraft {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  venueId String
  venue   Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  contactId String?
  contact   MarketingContact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  toEmailNormalized String
  status            MarketingOutreachDraftStatus @default(PENDING_REVIEW)

  subject  String
  textBody String @db.Text
  htmlBody String @db.Text

  discoveryMarketSlug String?

  approvedAt      DateTime?
  approvedByEmail String?
  rejectedAt      DateTime?
  rejectedByEmail String?

  sentAt    DateTime?
  lastError String?

  marketingEmailSendId String?            @unique
  emailSend            MarketingEmailSend? @relation(fields: [marketingEmailSendId], references: [id], onDelete: SetNull)

  @@index([venueId, status])
  @@index([status, createdAt])
}

/// Immutable send audit trail (includes blocked attempts).
model MarketingEmailSend {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contactId String?
  contact   MarketingContact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  toEmailNormalized String
  toDomain          String

  category       MarketingEmailCategory
  templateKind   String
  purposeKey     String
  idempotencyKey String @unique

  subject String

  status            MarketingEmailSendStatus @default(QUEUED)
  blockedReason     String?
  providerMessageId String?
  sentAt            DateTime?
  failedAt          DateTime?
  lastError         String?

  venueId String?
  venue   Venue? @relation(fields: [venueId], references: [id], onDelete: SetNull)

  discoveryMarketSlug String?

  outreachDraft            MarketingOutreachDraft?
  growthLeadOutreachDraft GrowthLeadOutreachDraft?

  @@index([contactId, createdAt])
  @@index([category, sentAt])
  @@index([toDomain, sentAt])
  @@index([status, createdAt])
  @@index([templateKind])
}

/// Inbound provider hooks (bounces/complaints) — populate when webhooks are configured.
model MarketingProviderWebhookEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  provider   String
  eventType  String
  externalId String?
  payload    Json
  processedAt DateTime?

  @@index([provider, createdAt])
  @@index([processedAt])
}

/// Global email-level suppression even when no `MarketingContact` row exists yet.
model MarketingEmailSuppression {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  emailNormalized String               @unique
  reason          MarketingSuppressionReason
  sourceNote      String?

  @@index([reason])
}

// --- Growth / outbound lead pipeline (manual, CSV, scheduled discovery adapters; cold send never auto-fired) ---

enum GrowthLeadType {
  VENUE
  ARTIST
  PROMOTER_ACCOUNT
}

enum GrowthLeadStatus {
  DISCOVERED
  REVIEWED
  APPROVED
  CONTACTED
  REPLIED
  /// Lead became a real MicStage venue owner, artist, or similar participant.
  JOINED
  BOUNCED
  UNSUBSCRIBED
  REJECTED
}

enum GrowthLeadPerformanceTag {
  MUSIC
  COMEDY
  POETRY
  VARIETY
}

/// Where the lead row originated (ingestion path).
enum GrowthLeadSourceKind {
  MANUAL_ADMIN
  CSV_IMPORT
  WEBSITE_CONTACT
  SOCIAL_PROFILE
  EVENT_LISTING
  SCHEDULED_JOB
}

enum GrowthLeadOutreachDraftStatus {
  PENDING_REVIEW
  APPROVED
  SENT
  REJECTED
}

enum GrowthLeadResponseChannel {
  EMAIL
  NOTE
  OTHER
}

enum GrowthLeadFollowUpStatus {
  PLANNED
  CANCELLED
  SKIPPED
  COMPLETED
}

/// Autonomous venue discovery: explicit open-mic language vs inferred live-event fit.
enum GrowthLeadOpenMicSignalTier {
  EXPLICIT_OPEN_MIC
  STRONG_LIVE_EVENT
  WEAK_INFERRED
}

enum GrowthLeadContactQuality {
  EMAIL
  CONTACT_PAGE
  SOCIAL_OR_CALENDAR
  WEBSITE_ONLY
}

/// Lightweight venue outreach funnel (advance-only in code; admin can set manually).
enum GrowthLeadAcquisitionStage {
  DISCOVERED
  OUTREACH_DRAFTED
  OUTREACH_SENT
  CLICKED
  SIGNUP_STARTED
  ACCOUNT_CREATED
  LISTING_LIVE
}

/// Imported or hand-entered prospect; outreach is draft → approve → send only.
model GrowthLead {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leadType GrowthLeadType
  status   GrowthLeadStatus @default(DISCOVERED)

  name String

  /// Normalized email when available (outreach sends require this).
  contactEmailNormalized String?
  /// Booking / contact page when no email yet.
  contactUrl             String?

  websiteUrl   String?
  instagramUrl String?
  youtubeUrl   String?
  tiktokUrl    String?
  facebookUrl  String?

  city                String?
  /// Suburb or neighborhood within the metro (e.g. Evanston under Chicagoland).
  suburb              String?
  region              String?
  discoveryMarketSlug String?

  performanceTags GrowthLeadPerformanceTag[] @default([])

  source     String?
  sourceKind GrowthLeadSourceKind @default(MANUAL_ADMIN)
  /// 0–100 heuristic from discovery adapters (optional).
  discoveryConfidence Int?

  fitScore Int?

  openMicSignalTier GrowthLeadOpenMicSignalTier?
  contactQuality    GrowthLeadContactQuality?
  acquisitionStage  GrowthLeadAcquisitionStage @default(DISCOVERED)

  /// Optional stable key for import dedupe (e.g. CSV row id or domain).
  importKey String? @unique

  /// Normalized hostname for dedupe (lowercase, no www).
  websiteHostNormalized String?
  /// Normalized Instagram handle without @ (lowercase).
  instagramHandleNormalized String?

  internalNotes String? @db.Text

  outreachDrafts  GrowthLeadOutreachDraft[]
  responses       GrowthLeadResponse[]
  followUpSchedules GrowthLeadFollowUpSchedule[]

  @@index([leadType, status])
  @@index([discoveryMarketSlug])
  @@index([suburb])
  @@index([status, createdAt])
  @@index([contactEmailNormalized])
  @@index([websiteHostNormalized, leadType])
  @@index([instagramHandleNormalized, leadType])
  @@index([openMicSignalTier])
  @@index([contactQuality])
  @@index([acquisitionStage])
  @@index([leadType, openMicSignalTier])
}

/// Pagination / rotation state for autonomous discovery adapters (per adapter + market).
model GrowthDiscoveryCursor {
  id         String   @id @default(cuid())
  updatedAt  DateTime @updatedAt
  adapterId  String
  marketSlug String
  cursorKey  String
  value      String   @db.Text

  @@unique([adapterId, marketSlug, cursorKey])
  @@index([adapterId, marketSlug])
}

model GrowthLeadOutreachDraft {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leadId String
  lead   GrowthLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  contactId String?
  contact   MarketingContact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  toEmailNormalized String
  status            GrowthLeadOutreachDraftStatus @default(PENDING_REVIEW)

  subject  String
  textBody String @db.Text
  htmlBody String @db.Text

  discoveryMarketSlug String?

  approvedAt      DateTime?
  approvedByEmail String?
  rejectedAt      DateTime?
  rejectedByEmail String?

  sentAt    DateTime?
  lastError String?

  marketingEmailSendId String?            @unique
  emailSend            MarketingEmailSend? @relation(fields: [marketingEmailSendId], references: [id], onDelete: SetNull)

  @@index([leadId, status])
  @@index([status, createdAt])
}

model GrowthLeadResponse {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  leadId String
  lead   GrowthLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  channel GrowthLeadResponseChannel @default(NOTE)
  summary String                    @db.Text
  meta    Json?

  actorEmail String?

  @@index([leadId, createdAt])
}

/// Follow-up hooks for future automation; `enabled` defaults false — no worker sends yet.
model GrowthLeadFollowUpSchedule {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leadId String
  lead   GrowthLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  /// Master switch per row; global automation stays off until product enables it.
  enabled Boolean @default(false)

  runAfter   DateTime?
  templateKey String?

  status GrowthLeadFollowUpStatus @default(PLANNED)

  lastError String?

  @@index([enabled, runAfter])
  @@index([leadId])
}

/// Outbound growth launch queue + auto-expansion (MicStage markets).
enum GrowthLaunchMarketStatus {
  ACTIVE
  QUEUED
  PAUSED
}

model GrowthLaunchMarket {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  discoveryMarketSlug String @unique
  label               String
  regionDefault       String?

  status    GrowthLaunchMarketStatus @default(QUEUED)
  sortOrder Int                       @default(0)

  activatedAt DateTime?
  pausedAt    DateTime?

  coldApprovalRelaxed  Boolean @default(false)
  autoExpansionEnabled Boolean @default(true)

  notes String?

  @@index([status, sortOrder])
}
